# Owner admin login email/username for the hidden /admin route.
ADMIN_EMAIL=

# Strong owner admin password for the hidden /admin route.
ADMIN_PASSWORD=

# Optional server-side Gemini API key used by the AI report routes.
GEMINI_API_KEY=

# Optional Supabase project URL for auth/database/storage integration.
NEXT_PUBLIC_SUPABASE_URL=

# Optional Supabase anon key. Safe for browser use when RLS is configured.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Supabase service role key. Server-side only; never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=

# Optional canonical deployment URL used for metadata and links.
NEXT_PUBLIC_APP_URL=

# Optional internal-only switch for silent demo account access in production.
# Keep unset or false on public launches unless the owner explicitly needs it.
ENABLE_INTERNAL_DEMO_ACCOUNTS=false
